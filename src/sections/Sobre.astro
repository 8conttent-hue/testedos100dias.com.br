---
// Sobre-A: Clássica centralizada — hero gradiente + conteúdo + missão
interface Props {
  title: string;
  subtitle: string;
  content: string;
  mission?: string;
  image?: string;
}
const { title, subtitle, content, mission, image } = Astro.props;
---
<!-- Hero -->
<section class="relative py-24 text-white text-center overflow-hidden" style={image ? `background: url(${image}) center/cover no-repeat` : ''}>
  <div class={`absolute inset-0 ${image ? 'bg-gradient-to-br from-dark/80 via-accent/70 to-dark/80' : 'bg-gradient-to-br from-dark to-accent'}`}></div>
  <div class="relative z-10 max-w-3xl mx-auto px-4">
    <span class="inline-block text-xs font-bold uppercase tracking-widest text-primary/90 bg-white/10 border border-white/20 px-4 py-1.5 rounded-full mb-6">
      Quem Somos
    </span>
    <h1 class="text-4xl md:text-5xl font-black mb-6 leading-tight">{title}</h1>
    <p class="text-white/70 text-xl leading-relaxed">{subtitle}</p>
  </div>
</section>

<!-- Conteúdo -->
<section class="py-20 bg-white">
  <div class="max-w-3xl mx-auto px-4">
    <p class="text-gray-600 leading-relaxed text-lg">{content}</p>

    {mission && (
      <div class="mt-12 p-8 bg-primary/5 border border-primary/10 rounded-3xl">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center text-white text-sm">✦</div>
          <h3 class="text-xl font-black text-dark">Nossa Missão</h3>
        </div>
        <p class="text-gray-600 leading-relaxed">{mission}</p>
      </div>
    )}

    <!-- Stats -->
    <div class="mt-16 grid grid-cols-3 gap-6 text-center">
      <div class="p-6 rounded-2xl bg-gray-50">
        <div class="text-3xl font-black text-primary mb-1">5+</div>
        <div class="text-sm text-gray-500">Anos de experiência</div>
      </div>
      <div class="p-6 rounded-2xl bg-gray-50">
        <div class="text-3xl font-black text-primary mb-1">300+</div>
        <div class="text-sm text-gray-500">Posts publicados</div>
      </div>
      <div class="p-6 rounded-2xl bg-gray-50">
        <div class="text-3xl font-black text-primary mb-1">50K</div>
        <div class="text-sm text-gray-500">Leitores mensais</div>
      </div>
    </div>
  </div>
</section>