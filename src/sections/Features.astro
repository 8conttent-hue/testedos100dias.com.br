---
// Features-C: Alternando imagem/texto por item
interface Item { icon: string; title: string; desc: string; }
interface Props { title: string; items: Item[]; }
const { title, items } = Astro.props;
---
<section class="py-20 bg-gray-50">
  <div class="max-w-5xl mx-auto px-4">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-black text-dark">{title}</h2>
    </div>

    <!-- Itens alternados -->
    <div class="space-y-16">
      {items.map((item, i) => (
        <div class={`flex flex-col md:flex-row items-center gap-10 ${i % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
          <!-- Bloco visual -->
          <div class="md:w-1/2 shrink-0">
            <div class="aspect-video bg-gradient-to-br from-primary/10 to-accent/5 rounded-3xl flex items-center justify-center text-7xl border border-primary/10">
              {item.icon}
            </div>
          </div>

          <!-- Texto -->
          <div class="md:w-1/2">
            <div class="text-xs font-bold uppercase tracking-widest text-primary mb-3">
              Recurso 0{i + 1}
            </div>
            <h3 class="text-2xl font-black text-dark mb-4">{item.title}</h3>
            <p class="text-gray-500 leading-relaxed">{item.desc}</p>
            <a
              href="/blog"
              class="inline-flex items-center gap-2 mt-6 text-primary font-bold text-sm hover:gap-3 transition-all"
            >
              Saiba mais
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>